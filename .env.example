APP_NAME=google_auth_service
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
APP_LOG_LEVEL=INFO
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
TASK_SERVICE_PORT=8002
SCHEDULE_SERVICE_PORT=8004
STATS_SERVICE_PORT=8005
NOTIFICATIONS_SERVICE_PORT=8006
GOOGLE_AUTH_SERVICE_PORT=8007
CALENDAR_SERVICE_PORT=8008
GOOGLEFIT_SERVICE_PORT=8009
STT_SERVICE_PORT=8010
AGENT_SERVICE_PORT=8011

POSTGRES_USER=kairos_user
POSTGRES_PASSWORD=kairos_password
POSTGRES_DB=kairos_db
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_HOST=redis
REDIS_DB=0

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

CALENDAR_PORT=8001
GOOGLE_FIT_PORT=8002

AUTH_DB_HOST=auth_postgres
AUTH_DB_PORT=5432
AUTH_DB_LOCAL_PORT=5433
AUTH_DB_USER=kairos_auth_user
AUTH_DB_PASSWORD=kairos_auth_password
AUTH_DB_NAME=kairos_auth_db

TASK_DB_HOST=task_postgres
TASK_DB_PORT=5432
TASK_DB_LOCAL_PORT=5434
TASK_DB_USER=kairos_task_user
TASK_DB_PASSWORD=kairos_task_password
TASK_DB_NAME=kairos_task_db

SCHEDULE_DB_HOST=schedule_postgres
SCHEDULE_DB_PORT=5432
SCHEDULE_DB_LOCAL_PORT=5435
SCHEDULE_DB_USER=kairos_user
SCHEDULE_DB_PASSWORD=kairos_password
SCHEDULE_DB_NAME=kairos_schedule_db

STATS_DB_HOST=stats_postgres
STATS_DB_PORT=5432
STATS_DB_LOCAL_PORT=5436
STATS_DB_USER=kairos_stats_user
STATS_DB_PASSWORD=kairos_stats_password
STATS_DB_NAME=kairos_stats_db

NOTIFICATIONS_DB_HOST=notifications_postgres
NOTIFICATIONS_DB_PORT=5432
NOTIFICATIONS_DB_LOCAL_PORT=5437
NOTIFICATIONS_DB_USER=kairos_notifications_user
NOTIFICATIONS_DB_PASSWORD=kairos_notifications_password
NOTIFICATIONS_DB_NAME=kairos_notifications_db

JWT_SECRET=change_me_for_local_development
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=10080

GOOGLE_FIT_API_BASE=https://www.googleapis.com/fitness/v1/users/me
GOOGLE_FIT_SCOPES=https://www.googleapis.com/auth/fitness.sleep.write https://www.googleapis.com/auth/fitness.sleep.read https://www.googleapis.com/auth/fitness.oxygen_saturation.write https://www.googleapis.com/auth/fitness.oxygen_saturation.read https://www.googleapis.com/auth/fitness.nutrition.write https://www.googleapis.com/auth/fitness.nutrition.read https://www.googleapis.com/auth/fitness.location.write https://www.googleapis.com/auth/fitness.location.read https://www.googleapis.com/auth/fitness.heart_rate.write https://www.googleapis.com/auth/fitness.heart_rate.read https://www.googleapis.com/auth/fitness.body.write https://www.googleapis.com/auth/fitness.body.read https://www.googleapis.com/auth/fitness.body_temperature.write https://www.googleapis.com/auth/fitness.body_temperature.read https://www.googleapis.com/auth/fitness.blood_pressure.write https://www.googleapis.com/auth/fitness.blood_pressure.read https://www.googleapis.com/auth/fitness.blood_glucose.write https://www.googleapis.com/auth/fitness.blood_glucose.read https://www.googleapis.com/auth/fitness.activity.write https://www.googleapis.com/auth/fitness.activity.read
FIT_BUCKET_DAYS=1

# Comma-separated list of origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000

# Google OAuth2 / OpenID Connect.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_REDIRECT_URIS=http://localhost:8000/auth/google/callback,kairos://auth/google/callback,https://auth.expo.io/@your-expo-username/kairos/auth/google/callback
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URI=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_AUTH_URL=http://google_auth:8000
CALENDAR_SERVICE_URL=http://calendar-service:8000
GOOGLE_FIT_URL=http://googlefit_service:8000
AUTH_SERVICE_URL=http://auth_service:8000
SCHEDULE_SERVICE_URL=http://schedule_service:8000
TASK_SERVICE_URL=http://task_service:8000
STT_SERVICE_URL=http://stt_service:8000
NOTIFICATIONS_SERVICE_URL=http://notifications_service:8000
STATS_SERVICE_URL=http://stats_service:8000
AGENT_SERVICE_URL=http://agent_service:8000
REQUEST_TIMEOUT_SECONDS=20
GOOGLE_SCOPE=openid email profile https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/fitness.sleep.write https://www.googleapis.com/auth/fitness.sleep.read https://www.googleapis.com/auth/fitness.oxygen_saturation.write https://www.googleapis.com/auth/fitness.oxygen_saturation.read https://www.googleapis.com/auth/fitness.nutrition.write https://www.googleapis.com/auth/fitness.nutrition.read https://www.googleapis.com/auth/fitness.location.write https://www.googleapis.com/auth/fitness.location.read https://www.googleapis.com/auth/fitness.heart_rate.write https://www.googleapis.com/auth/fitness.heart_rate.read https://www.googleapis.com/auth/fitness.body.write https://www.googleapis.com/auth/fitness.body.read https://www.googleapis.com/auth/fitness.body_temperature.write https://www.googleapis.com/auth/fitness.body_temperature.read https://www.googleapis.com/auth/fitness.blood_pressure.write https://www.googleapis.com/auth/fitness.blood_pressure.read https://www.googleapis.com/auth/fitness.blood_glucose.write https://www.googleapis.com/auth/fitness.blood_glucose.read https://www.googleapis.com/auth/fitness.activity.write https://www.googleapis.com/auth/fitness.activity.read

# State token expiration, in seconds.
STATE_TTL_SECONDS=600
